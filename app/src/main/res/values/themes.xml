<?xml version="1.0" encoding="utf-8"?>
<resources>
    
    <!-- Material Design 3 Base Theme -->
    <style name="Theme.GoGoGo" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/md_theme_primary</item>
        <item name="colorOnPrimary">@color/md_theme_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_onPrimaryContainer</item>
        
        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/md_theme_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_onSecondaryContainer</item>
        
        <!-- Tertiary Colors -->
        <item name="colorTertiary">@color/md_theme_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_onTertiaryContainer</item>
        
        <!-- Error Colors -->
        <item name="colorError">@color/md_theme_error</item>
        <item name="colorOnError">@color/md_theme_onError</item>
        <item name="colorErrorContainer">@color/md_theme_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_theme_onErrorContainer</item>
        
        <!-- Surface & Background Colors -->
        <item name="android:colorBackground">@color/md_theme_background</item>
        <item name="colorOnBackground">@color/md_theme_onBackground</item>
        <item name="colorSurface">@color/md_theme_surface</item>
        <item name="colorOnSurface">@color/md_theme_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_onSurfaceVariant</item>
        
        <!-- Outline Colors -->
        <item name="colorOutline">@color/md_theme_outline</item>
        <item name="colorOutlineVariant">@color/md_theme_outlineVariant</item>
        
        <!-- Inverse Colors -->
        <item name="colorInversePrimary">@color/md_theme_inversePrimary</item>
        <item name="colorInverseSurface">@color/md_theme_inverseSurface</item>
        <item name="colorInverseOnSurface">@color/md_theme_inverseOnSurface</item>
        
        <!-- Scrim Color -->
        <item name="colorScrim">@color/md_theme_scrim</item>
        
        <!-- Material 3 Specific Attributes -->
        <item name="android:statusBarColor">@color/md_theme_surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/md_theme_surface</item>
        
        <!-- Shape Styles -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.GoGoGo.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.GoGoGo.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.GoGoGo.LargeComponent</item>
        
        <!-- Elevation Overlays -->
        <item name="elevationOverlayColor">@color/md_theme_primary</item>
        
        <!-- FAB Style -->
        <item name="floatingActionButtonStyle">@style/Widget.GoGoGo.FloatingActionButton</item>
        
        <!-- Button Styles -->
        <item name="materialButtonStyle">@style/Widget.GoGoGo.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.GoGoGo.Button.Outlined</item>
        <item name="borderlessButtonStyle">@style/Widget.GoGoGo.Button.Borderless</item>
        
        <!-- Text Field Styles -->
        <item name="textInputStyle">@style/Widget.GoGoGo.TextInputLayout.OutlinedBox</item>
        <item name="textInputOutlinedStyle">@style/Widget.GoGoGo.TextInputLayout.OutlinedBox</item>
        
        <!-- Card Styles -->
        <item name="materialCardViewStyle">@style/Widget.GoGoGo.CardView</item>
        
        <!-- Navigation Styles -->
        <item name="bottomNavigationStyle">@style/Widget.GoGoGo.BottomNavigationView</item>
        <item name="navigationRailStyle">@style/Widget.GoGoGo.NavigationRail</item>
    </style>
    
    <!-- Main Activity Theme with Edge-to-Edge -->
    <style name="Theme.GoGoGo.Main" parent="Theme.GoGoGo">
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
    
    <!-- Shape Appearances for Material 3 -->
    <style name="ShapeAppearance.GoGoGo.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    
    <!-- Toolbar Shape Appearance -->
    <style name="ShapeAppearanceOverlay.GoGoGo.Toolbar" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    
    <style name="ShapeAppearance.GoGoGo.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    
    <style name="ShapeAppearance.GoGoGo.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>
    
    <!-- FAB Styles -->
    <style name="Widget.GoGoGo.FloatingActionButton" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/md_theme_primary</item>
        <item name="tint">@color/md_theme_onPrimary</item>
        <item name="elevation">6dp</item>
    </style>
    
    <!-- Button Styles -->
    <style name="Widget.GoGoGo.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/md_theme_primary</item>
        <item name="iconTint">@color/md_theme_onPrimary</item>
        <item name="insetTop">0dp</item>
        <item name="insetBottom">0dp</item>
        <item name="cornerRadius">12dp</item>
    </style>
    
    <style name="Widget.GoGoGo.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/md_theme_outline</item>
        <item name="insetTop">0dp</item>
        <item name="insetBottom">0dp</item>
        <item name="cornerRadius">12dp</item>
    </style>
    
    <style name="Widget.GoGoGo.Button.Borderless" parent="Widget.Material3.Button.TextButton">
        <item name="insetTop">0dp</item>
        <item name="insetBottom">0dp</item>
        <item name="cornerRadius">12dp</item>
    </style>
    
    <!-- Text Field Styles -->
    <style name="Widget.GoGoGo.TextInputLayout.OutlinedBox" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="hintTextColor">@color/md_theme_onSurfaceVariant</item>
        <item name="boxStrokeColor">@color/md_theme_outline</item>
    </style>
    
    <!-- Card Styles -->
    <style name="Widget.GoGoGo.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">2dp</item>
    </style>
    
    <!-- Navigation Styles -->
    <style name="Widget.GoGoGo.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/Widget.GoGoGo.BottomNavigationView.ActiveIndicator</item>
    </style>
    
    <style name="Widget.GoGoGo.BottomNavigationView.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:width">56dp</item>
        <item name="android:height">32dp</item>
        <item name="itemActiveIndicatorColor">@color/md_theme_primaryContainer</item>
    </style>
    
    <style name="Widget.GoGoGo.NavigationRail" parent="Widget.Material3.NavigationRailView">
        <item name="elevation">3dp</item>
    </style>
    
    <!-- Dialog Styles -->
    <style name="ThemeOverlay.GoGoGo.Dialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="dialogCornerRadius">28dp</item>
    </style>
    
    <!-- Snackbar Styles -->
    <style name="ThemeOverlay.GoGoGo.Snackbar" parent="ThemeOverlay.Material3.Snackbar">
        <item name="snackbarStyle">@style/Widget.GoGoGo.Snackbar</item>
    </style>
    
    <style name="Widget.GoGoGo.Snackbar" parent="Widget.Material3.Snackbar">
        <item name="backgroundTint">@color/md_theme_inverseSurface</item>
        <item name="elevation">6dp</item>
        <item name="cornerRadius">8dp</item>
    </style>
    
</resources>
