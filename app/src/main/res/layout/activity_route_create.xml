<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.baidu.mapapi.map.MapView
        android:id="@+id/map_create"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="点击地图绘制路线"
        android:background="#80000000"
        android:textColor="#FFFFFF"
        android:padding="5dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp"/>

    <ImageButton
        android:id="@+id/btn_create_location"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_above="@+id/layout_bottom_control"
        android:layout_marginBottom="20dp"
        android:layout_marginStart="20dp"
        android:layout_alignParentStart="true"
        android:background="@drawable/circle_shape_bg"
        android:src="@drawable/ic_position"
        android:scaleType="centerInside"
        android:padding="8dp"/>

    <LinearLayout
        android:id="@+id/layout_bottom_control"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#FFFFFFFF"
        android:padding="10dp">

        <Button
            android:id="@+id/btn_create_clear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="清除重画"
            android:layout_marginEnd="5dp"/>

        <Button
            android:id="@+id/btn_create_save"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="保存路线"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="#FFFFFF"
            android:layout_marginStart="5dp"/>
    </LinearLayout>
</RelativeLayout>